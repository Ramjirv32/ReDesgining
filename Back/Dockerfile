# ── Stage 1: Build ────────────────────────────────────────────────────────────
FROM golang:1.24-alpine AS builder

RUN apk add --no-cache git ca-certificates tzdata

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w" -o server ./main.go

# ── Stage 2: Run ──────────────────────────────────────────────────────────────
FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

COPY --from=builder /app/server .

# ── Build-time env args (hardcoded into image) ────────────────────────────────
ARG PORT=9000
ARG MONGODB_URI
ARG CLOUDINARY_URL
ARG JWT_SECRET
ARG NEXT_PUBLIC_RAZORPAY_KEY_ID
ARG RAZORPAY_KEY_SECRET
ARG CASHFREE_CLIENT_ID
ARG CASHFREE_CLIENT_SECRET
ARG CASHFREE_VERIFICATION_URL
ARG CASHFREE_PAYMENT_URL
ARG PAYMENT_TRAFFIC_WEIGHT_CASHFREE
ARG NEXT_PUBLIC_FIREBASE_API_KEY
ARG NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
ARG NEXT_PUBLIC_FIREBASE_PROJECT_ID
ARG NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
ARG NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
ARG NEXT_PUBLIC_FIREBASE_APP_ID
ARG PLAY_EMAIL
ARG PLAY_APP_PASSWORD
ARG DINING_EMAIL
ARG DINING_APP_PASSWORD
ARG EVENTS_EMAIL
ARG EVENTS_APP_PASSWORD
ARG ADMIN_EMAIL
ARG ADMIN_PASSWORD
ARG ADMIN_APP_PASSWORD

ENV PORT=${PORT} \
    MONGODB_URI=${MONGODB_URI} \
    CLOUDINARY_URL=${CLOUDINARY_URL} \
    JWT_SECRET=${JWT_SECRET} \
    NEXT_PUBLIC_RAZORPAY_KEY_ID=${NEXT_PUBLIC_RAZORPAY_KEY_ID} \
    RAZORPAY_KEY_SECRET=${RAZORPAY_KEY_SECRET} \
    CASHFREE_CLIENT_ID=${CASHFREE_CLIENT_ID} \
    CASHFREE_CLIENT_SECRET=${CASHFREE_CLIENT_SECRET} \
    CASHFREE_VERIFICATION_URL=${CASHFREE_VERIFICATION_URL} \
    CASHFREE_PAYMENT_URL=${CASHFREE_PAYMENT_URL} \
    PAYMENT_TRAFFIC_WEIGHT_CASHFREE=${PAYMENT_TRAFFIC_WEIGHT_CASHFREE} \
    NEXT_PUBLIC_FIREBASE_API_KEY=${NEXT_PUBLIC_FIREBASE_API_KEY} \
    NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=${NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN} \
    NEXT_PUBLIC_FIREBASE_PROJECT_ID=${NEXT_PUBLIC_FIREBASE_PROJECT_ID} \
    NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=${NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET} \
    NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=${NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID} \
    NEXT_PUBLIC_FIREBASE_APP_ID=${NEXT_PUBLIC_FIREBASE_APP_ID} \
    PLAY_EMAIL=${PLAY_EMAIL} \
    PLAY_APP_PASSWORD=${PLAY_APP_PASSWORD} \
    DINING_EMAIL=${DINING_EMAIL} \
    DINING_APP_PASSWORD=${DINING_APP_PASSWORD} \
    EVENTS_EMAIL=${EVENTS_EMAIL} \
    EVENTS_APP_PASSWORD=${EVENTS_APP_PASSWORD} \
    ADMIN_EMAIL=${ADMIN_EMAIL} \
    ADMIN_PASSWORD=${ADMIN_PASSWORD} \
    ADMIN_APP_PASSWORD=${ADMIN_APP_PASSWORD}

EXPOSE 9000

CMD ["./server"]
